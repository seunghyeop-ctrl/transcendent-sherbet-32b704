# Web server
PORT=5001
PROMPT_EXTRACTOR_HOST=0.0.0.0
PROMPT_EXTRACTOR_PUBLIC_URL=https://your-service.onrender.com

# Gemini
GEMINI_API_KEY=your_gemini_api_key

# Google Sheets
PROMPT_EXTRACTOR_GOOGLE_SHEET_ID=your_google_sheet_id
PROMPT_EXTRACTOR_WORKSHEET=Sheet1

# Optional runtime paths inside server/container
PROMPT_EXTRACTOR_APP_DIR=/tmp/prompt-extractor-app
PROMPT_EXTRACTOR_OUTPUT_DIR=/tmp/prompt-extractor-data
PROMPT_EXTRACTOR_CREDENTIALS_PATH=/tmp/prompt-extractor-app/credentials.json

# Option 1: put full service-account JSON here as one line
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
